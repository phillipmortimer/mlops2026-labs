# Copy this file to .env and fill in the values for your lab group.
#
# Do not commit .env. It contains secrets and is ignored by Git.

# OpenAI API key for the course/lab project.
OPENAI_API_KEY=

# Low-cost model for normal lab runs.
OPENAI_MODEL=gpt-5-mini

# Cheaper fallback for repeated tests or simple variants.
OPENAI_FALLBACK_MODEL=gpt-5-nano

# Langfuse project credentials.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Use a stable group identifier so traces can be filtered in Langfuse.
GROUP_ID=group-00

